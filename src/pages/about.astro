---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { aboutContent } from "../config/content.ts";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{aboutContent.meta.title}</title>
    <meta name="description" content={aboutContent.meta.description} />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "dark";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const initialTheme =
          savedTheme === "system"
            ? prefersDark
              ? "dark"
              : "light"
            : savedTheme;

        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", (e) => {
            if (localStorage.getItem("theme") === "system") {
              if (e.matches) {
                document.documentElement.classList.add("dark");
              } else {
                document.documentElement.classList.remove("dark");
              }
            }
          });
      });
    </script>
    <style>
      .dot-hexagon-light {
        background-image: radial-gradient(
            circle,
            #80808045 1px,
            transparent 1px
          ),
          radial-gradient(circle, #80808045 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }

      .dot-hexagon-dark {
        background-image: radial-gradient(
            circle,
            #ffffff35 1px,
            transparent 1px
          ),
          radial-gradient(circle, #ffffff35 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position:
          0 0,
          12px 20.78px;
      }
    </style>
  </head>
  <body
    class="min-h-screen flex flex-col bg-white dark:bg-neutral-900 transition-colors duration-300"
  >
    <div class="relative flex-grow flex flex-col">
      <div class="absolute inset-0 z-0">
        <div
          class="absolute inset-0 -z-10 dot-hexagon-light dark:dot-hexagon-dark"
        >
        </div>
        <div
          class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(255,255,255,0.5)_60%,rgba(255,255,255,0.9)_85%,white_100%)] dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(23,23,23,0.5)_60%,rgba(23,23,23,0.9)_85%,rgb(23,23,23)_100%)] -z-10"
        >
        </div>
        <div
          class="absolute left-0 right-0 top-0 -z-10 m-auto h-[1200px] w-[1200px] rounded-full bg-neutral-400 opacity-10 blur-[100px]"
        >
        </div>
      </div>

      <Navigation />
      <section class="relative z-20 w-full max-w-4xl mx-auto mt-24 mb-12 px-4 md:px-0">
        <div class="relative z-20 w-full mx-auto lg:mx-0">
          <h2
            class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-3xl lg:text-4xl"
          >
            {aboutContent.title}
          </h2>
          <div class="flex flex-col md:flex-row gap-8 mt-3 sm:mt-4 lg:mt-6">
            <div class="w-full md:w-1/2 flex flex-col">
              <div class="space-y-6">
                <div>
                  <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-3">Technical Skills</h3>
                  <div class="flex flex-wrap gap-2">
                    {
                      aboutContent.technicalSkills.map((techSkill) => (
                        <span class="px-3 py-1 text-sm bg-neutral-200 dark:bg-neutral-700 text-neutral-700 dark:text-neutral-200 rounded-full">
                          {techSkill}
                        </span>
                      ))
                    }
                  </div>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-3">Languages</h3>
                  <div class="flex flex-wrap gap-2">
                    {
                      aboutContent.languages.map((language) => (
                        <span class="px-3 py-1 text-sm bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full">
                          {language}
                        </span>
                      ))
                    }
                  </div>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100 mb-3">Soft Skills</h3>
                  <div class="flex flex-wrap gap-2">
                    {
                      aboutContent.softSkills.map((skill) => (
                        <span class="px-3 py-1 text-sm bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 rounded-full">
                          {skill}
                        </span>
                      ))
                    }
                  </div>
                </div>
              </div>
            </div>
            <div class="w-full md:w-1/2 flex justify-center md:justify-end">
              <div class="relative w-[280px] h-[280px] md:w-[360px] md:h-[360px]">
                <img
                  src={aboutContent.image.src}
                  alt={aboutContent.image.alt}
                  class="object-cover rounded-xl w-full h-full"
                />
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col md:flex-row mt-20">
          <div class="flex-1">
            <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">
              {aboutContent.experience.title}
            </h2>
            <div class="py-10">
              {
                aboutContent.experience.items.map((item) => (
                  <div class="pb-10 border-l border-gray-200 last:border-l-0 dark:border-neutral-700">
                    <div class="relative flex flex-col justify-start pl-12">
                      <div class="absolute top-0 left-0 z-40 flex items-center justify-center -translate-x-1/2 bg-white border rounded-full dark:bg-neutral-950 w-14 h-14 border-neutral-300 dark:border-neutral-700">
                        {item.icon === "movie" ? (
                          <svg
                            class="w-8 h-8 text-neutral-700 dark:text-neutral-300"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="1.5"
                              d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"
                            />
                          </svg>
                        ) : item.icon === "theatre" ? (
                          <svg
                            class="w-8 h-8 text-neutral-700 dark:text-neutral-300"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="1.5"
                              d="M7 5h10a2 2 0 012 2v5a7 7 0 01-14 0V7a2 2 0 012-2zm2 4a1 1 0 100 2 1 1 0 000-2zm6 0a1 1 0 100 2 1 1 0 000-2zm0 4c-.8.6-1.7 1-3 1s-2.2-.4-3-1"
                            />
                          </svg>
                        ) : (
                          <svg
                            class="w-8 h-8 text-neutral-700 dark:text-neutral-300"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="1.5"
                              d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                            />
                          </svg>
                        )}
                      </div>
                      <p class="text-xs uppercase text-neutral-400 dark:text-neutral-500 tracking-widest">
                        {item.period}
                      </p>
                      {item.link ? (
                        <a href={item.link} target="_blank" rel="noopener noreferrer" class="my-1 text-lg font-bold dark:text-neutral-100 hover:underline">
                          {item.position}
                        </a>
                      ) : (
                        <h3 class="my-1 text-lg font-bold dark:text-neutral-100">
                          {item.position}
                        </h3>
                      )}
                      <p class="mb-1 text-sm font-medium dark:text-neutral-300">
                        {item.company}
                      </p>
                      <p class="text-sm font-light text-neutral-600 dark:text-neutral-400">
                        {item.description}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="w-[360px] ml-8">
            <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">
              {aboutContent.aboutMe.title}
            </h2>
            <div class="py-[30px]">
              <p
                class="text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg"
              >
                {aboutContent.aboutMe.description}
              </p>
            </div>
          </div>
        </div>

        <div class="mt-20">
          <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">
            {aboutContent.education.title}
          </h2>
          <div class="py-10">
            {
              aboutContent.education.items.map((item) => (
                <div class="pb-10 border-l border-gray-200 last:border-l-0 dark:border-neutral-700">
                  <div class="relative flex flex-col justify-start pl-12">
                    <div class="absolute top-0 left-0 z-40 flex items-center justify-center -translate-x-1/2 bg-white border rounded-full dark:bg-neutral-950 w-14 h-14 border-neutral-300 dark:border-neutral-700">
                      <svg
                        class="w-8 h-8 text-neutral-700 dark:text-neutral-300"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.5"
                          d="M12 14l9-5-9-5-9 5 9 5z"
                        />
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="1.5"
                          d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                        />
                      </svg>
                    </div>
                    <p class="text-xs uppercase text-neutral-400 dark:text-neutral-500 tracking-widest">
                      {item.period}
                    </p>
                    <a href={item.link} class="my-1 text-lg font-bold dark:text-neutral-100 hover:underline" target="_blank" rel="noopener noreferrer">
                      {item.degree}
                    </a>
                    <p class="mb-1 text-sm font-medium dark:text-neutral-300">
                      {item.institution}
                    </p>
                    <p class="text-sm font-light text-neutral-600 dark:text-neutral-400">
                      {item.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
    </div>

    <Footer />
  </body>
</html>
